{
  "hosting": [
    {
      "target": "cinexa",
      "public": "public",
      "cleanUrls": true,
      "trailingSlash": false,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/browse",
          "destination": "/browse.html"
        }
      ]
    }
  ]
}